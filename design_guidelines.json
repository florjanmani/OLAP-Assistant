{
  "identity": {
    "name": "E1",
    "role": "Creative Designer",
    "principles": [
      "Fusion over Imitation: Mix Swiss Poster Design with Financial Terminal aesthetics.",
      "Emotion First: Clarity and Authority.",
      "Content is King: Data is the hero.",
      "Zoom In: Focus on the metrics.",
      "Negative Space: Use whitespace to separate data clusters.",
      "Contrast: High contrast for readability."
    ],
    "anti_patterns": [
      "No 'Inter' for headings.",
      "No center-aligned main layouts.",
      "No gradient overload.",
      "No generic 'SaaS Blue' (use International Klein Blue instead)."
    ]
  },
  "typography": {
    "fonts": {
      "heading": {
        "family": "Chivo, sans-serif",
        "url": "https://fonts.googleapis.com/css2?family=Chivo:wght@300;400;700;900&display=swap",
        "usage": "Headings, Big Numbers, KPIs",
        "weights": ["300", "700", "900"]
      },
      "body": {
        "family": "Manrope, sans-serif",
        "url": "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&display=swap",
        "usage": "UI Text, Labels, Tooltips",
        "weights": ["400", "500"]
      },
      "mono": {
        "family": "JetBrains Mono, monospace",
        "url": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap",
        "usage": "Data Tables, Code Snippets, Query Input",
        "weights": ["400", "500"]
      }
    },
    "rules": [
      "Headings (h1, h2) must use 'Chivo' with tight tracking ('tracking-tight').",
      "Data cells and inputs must use 'JetBrains Mono'.",
      "Body text uses 'Manrope'.",
      "Never center headings unless for a specific 'poster' effect."
    ]
  },
  "colors": {
    "theme_strategy": "Hybrid (Swiss Light Default / Pro Dark Toggle)",
    "light_mode": {
      "background": "#FDFDFD",
      "foreground": "#0A0A0A",
      "card": "#FFFFFF",
      "card_foreground": "#0A0A0A",
      "primary": "#0047AB",
      "primary_foreground": "#FFFFFF",
      "secondary": "#F0F0F0",
      "secondary_foreground": "#0A0A0A",
      "muted": "#F5F5F5",
      "muted_foreground": "#666666",
      "accent": "#FF3B30",
      "accent_foreground": "#FFFFFF",
      "border": "#E5E5E5",
      "input": "#E5E5E5",
      "ring": "#0047AB"
    },
    "dark_mode": {
      "background": "#050505",
      "foreground": "#EDEDED",
      "card": "#0A0A0A",
      "card_foreground": "#EDEDED",
      "primary": "#2979FF",
      "primary_foreground": "#000000",
      "secondary": "#1A1A1A",
      "secondary_foreground": "#EDEDED",
      "muted": "#1A1A1A",
      "muted_foreground": "#888888",
      "accent": "#FF453A",
      "accent_foreground": "#FFFFFF",
      "border": "#222222",
      "input": "#222222",
      "ring": "#2979FF"
    },
    "semantic": {
      "success": "#34C759",
      "warning": "#FF9500",
      "error": "#FF3B30",
      "info": "#0047AB"
    }
  },
  "layout": {
    "spacing_scale": "p-1, p-2, p-4, p-6, p-8, p-12, p-16, p-20, p-24, p-32",
    "grid_system": {
      "mode": "Bento Grid Mode B (High Density)",
      "base": "grid-cols-1 md:grid-cols-12",
      "gap": "gap-4 md:gap-6",
      "rules": [
        "Sidebar: col-span-12 md:col-span-3 lg:col-span-2",
        "Main Content: col-span-12 md:col-span-9 lg:col-span-10",
        "Chart Containers: Must use 'h-full' to stretch."
      ]
    },
    "container_rules": [
      "Containers with borders must have internal padding (p-6 or p-8).",
      "Use 'max-w-screen-2xl' for the main dashboard wrapper."
    ]
  },
  "components": {
    "buttons": {
      "style": "Sharp edges or small radius (rounded-sm).",
      "variants": {
        "default": "bg-primary text-primary-foreground hover:bg-primary/90 shadow-none",
        "outline": "border border-input bg-background hover:bg-accent hover:text-accent-foreground",
        "ghost": "hover:bg-accent hover:text-accent-foreground"
      }
    },
    "cards": {
      "style": "Flat, 1px border, no shadow (Swiss Style).",
      "classes": "border border-border bg-card text-card-foreground rounded-none md:rounded-sm"
    },
    "inputs": {
      "style": "Minimalist, bottom border only OR flat box.",
      "classes": "border-input bg-transparent focus:ring-1 focus:ring-primary font-mono"
    },
    "charts": {
      "library": "Recharts",
      "style": "Minimalist. No grid lines (or very subtle). Clean axes. Tooltips must be high contrast.",
      "colors": ["#0047AB", "#FF3B30", "#00C7BE", "#AF52DE", "#FF9500"]
    },
    "chat_interface": {
      "style": "Tracing Beam or Floating Glass.",
      "input_area": "Fixed at bottom or distinct panel. Use 'JetBrains Mono' for the query input."
    }
  },
  "motion": {
    "library": "framer-motion",
    "presets": {
      "fade_in": { "initial": { "opacity": 0 }, "animate": { "opacity": 1 }, "transition": { "duration": 0.3 } },
      "slide_up": { "initial": { "y": 20, "opacity": 0 }, "animate": { "y": 0, "opacity": 1 }, "transition": { "duration": 0.4, "ease": "easeOut" } },
      "stagger_container": { "animate": { "transition": { "staggerChildren": 0.1 } } }
    },
    "rules": [
      "Respect 'prefers-reduced-motion'.",
      "Use 'layout' prop for smooth resizing of grids.",
      "No 'transition: all'."
    ]
  },
  "assets": {
    "icons": {
      "library": "lucide-react",
      "style": "Stroke width 1.5px or 2px. Consistent size."
    },
    "images": [
      {
        "category": "hero_background",
        "url": "https://images.unsplash.com/photo-1760143769741-9a215acf44cf?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzV8MHwxfHNlYXJjaHwzfHxhYnN0cmFjdCUyMGdlb21ldHJpYyUyMHNoYXBlcyUyMG1pbmltYWxpc3QlMjBkZXNpZ258ZW58MHx8fHwxNzY5NTkwOTYxfDA&ixlib=rb-4.1.0&q=85",
        "description": "Abstract blue geometric shapes for dark mode or hero background."
      },
      {
        "category": "login_bg",
        "url": "https://images.unsplash.com/photo-1737305467660-f7fce9a934bf?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2OTV8MHwxfHNlYXJjaHwzfHxtb2Rlcm4lMjBvZmZpY2UlMjBtaW5pbWFsaXN0JTIwaW50ZXJpb3J8ZW58MHx8fHwxNzY5NTkwOTYzfDA&ixlib=rb-4.1.0&q=85",
        "description": "Minimalist desk setup for login page."
      }
    ]
  },
  "tech_stack": {
    "frontend": "React, Tailwind CSS, Framer Motion, Lucide React, Recharts, Sonner",
    "backend": "FastAPI, Python",
    "components_path": "/app/frontend/src/components/ui"
  },
  "universal_guidelines": [
    "Do not use 'Inter' for headings.",
    "Do not use gradients for text.",
    "Use 'data-testid' for all interactive elements.",
    "Ensure contrast ratios meet APCA standards.",
    "Use 'sonner' for toasts.",
    "Components must use named exports.",
    "Pages must use default exports."
  ],
  "instructions_to_main_agent": "Follow the 'Swiss & High-Contrast' theme. Use the provided fonts (Chivo, Manrope, JetBrains Mono). Implement the 'Bento Grid' layout for the dashboard. Use Recharts for data visualization with the specified color palette. Ensure the chat interface feels responsive and 'alive' using Framer Motion."
}